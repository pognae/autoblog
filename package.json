{
  "name": "autoblog2",
  "version": "1.0.0",
  "private": true,
  "description": "티스토리 예약 자동 포스팅 프로그램 (Markdown -> Tistory)",
  "workspaces": [
    "server",
    "web"
  ],
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm run dev --workspace server",
    "dev:web": "npm run dev --workspace web",
    "build": "npm run build --workspace server && npm run build --workspace web",
    "start": "npm run start --workspace server",
    "oauth:login": "npx -y @openai/codex login",
    "oauth:proxy": "npx -y openai-oauth",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
