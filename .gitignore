node_modules/
dist/
*.log

# 로컬 데이터: 글감(posts)·DB·설정파일(app-config)은 배포에 포함.
# (민감정보는 모두 .env 전용이라 이 파일들엔 키/토큰이 들어가지 않음)
server/data/*
!server/data/posts/
!server/data/db.json
!server/data/app-config.json
!server/data/app-config.example.json
server/.session/
server/screenshots/
server/data/uploads/

# 환경변수
.env
.env.*
!.env.example
