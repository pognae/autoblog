# 백엔드 포트
PORT=4000

# 프론트엔드(개발 서버) 주소 - CORS 허용용
WEB_ORIGIN=http://localhost:5173

# 예약 글 확인 주기 (cron 표현식). 기본: 매 분
SCHEDULER_CRON=* * * * *

# 서버 시작 시 스케줄러 자동 실행 (false 로 끄기)
SCHEDULER_AUTOSTART=true

# 발행 자동화 브라우저 모드.
# true 면 headless(창 숨김)인데, 티스토리/카카오가 봇으로 감지해 로그인 페이지로 튕길 수 있음.
# 안정적인 발행을 위해 기본은 false(브라우저 창 표시) 권장.
PW_HEADLESS=false

# ChatGPT(OpenAI) API 키. 자동 글 생성에 필요.
# (UI 설정에서 입력해도 되지만, 여기에 두면 우선 사용됨)
OPENAI_API_KEY=

# 사용할 OpenAI 모델 (기본: gpt-4o-mini)
# OAuth 프록시(openai-oauth) 사용 시에는 gpt-5.4 등 Codex 플랜 모델로 지정.
OPENAI_MODEL=gpt-4o-mini

# OpenAI 호환 Base URL. 비우면 공식 API 사용.
# ChatGPT 계정 OAuth 로 API 키 없이 쓰려면 openai-oauth 프록시 주소 입력:
#   npm run oauth:login -> npm run oauth:proxy -> 아래 주석 해제
# OPENAI_BASE_URL=http://127.0.0.1:10531/v1
OPENAI_BASE_URL=

# Google Gemini API 키. (OpenAI 와 함께 등록하면 토큰 남은 쪽으로 자동 전환)
GEMINI_API_KEY=

# 사용할 Gemini 모델 (기본: gemini-2.5-flash)
# 참고: gemini-2.0-flash 는 무료 등급 한도가 0(limit:0)인 키 프로젝트가 많아 429 가 납니다.
GEMINI_MODEL=gemini-2.5-flash
