# =====================================================================
# AutoBlog 시크릿 (.env) — 민감정보만!
#
# 여기에는 "프로그램 구동에 꼭 필요한 키" + "GitHub 푸시 보호(시크릿)에 걸리는 값"만 둡니다.
# 비밀이 아닌 설정(포트·스케줄러·헤드리스·모델명·OpenAI Base URL)은 server/config.json,
# 화면 설정(블로그 이름·자동발행 일정·텔레그램 알림 종류/주기)은 server/data/app-config.json
# 에 저장되어 git/배포에 함께 포함됩니다. (→ .env 에 넣을 필요 없음)
#
# Cloudtype: 아래 KEY=VALUE 들을 서비스 "환경변수"에 등록하세요. (PORT 는 플랫폼이 자동 주입)
# =====================================================================

# AI API 키 (둘 중 최소 1개 필수)
OPENAI_API_KEY=
GEMINI_API_KEY=

# 텔레그램 상태 알림 (쓸 때만. 봇 토큰/채팅 ID 는 민감정보라 .env 전용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
